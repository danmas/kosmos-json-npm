{
  "name": "@roman.eremeev/kosmos-json-npm",
  "private": false,
  "version": "1.0.1",
  "type": "module",
  "description": "Super JSON Editor with tree mapping support",
  "main": "dist/super-json-editor.umd.js",
  "module": "dist/super-json-editor.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/super-json-editor.es.js",
      "require": "./dist/super-json-editor.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.5",
    "@uiw/react-codemirror": "^4.25.5",
    "clsx": "^2.1.1",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.7.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.3"
  },
  "publishConfig": {
    "access": "public"
  }
}